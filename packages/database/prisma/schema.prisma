// packages/database/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Unit {
  id        String   @id @default(uuid())
  name      String
  subdomain String   @unique
  settings  String?  // JSON string
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companies Company[]
  users     User[]
  providers Provider[]
}

model Company {
  id            String    @id @default(uuid())
  unitId        String
  externalCode  String?
  corporateName String
  tradeName     String?
  cnpj          String    @unique
  adminEmail    String?
  address       String?
  neighborhood  String?
  zipCode       String?
  city          String?
  state         String?
  phone         String?
  memberSince   DateTime?
  status        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  unit  Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)
  users User[]
}

model User {
  id            String    @id @default(uuid())
  companyId     String?
  unitId        String
  externalCode  String?
  fullName      String
  cpf           String
  type          String    // 'titular' or 'dependente'
  parentId      String?
  gender        String?
  birthDate     DateTime?
  phone         String?
  kinship       String?
  billingName   String?
  memberSince   DateTime?
  pointsBalance Int       @default(0)
  status        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  unit         Unit           @relation(fields: [unitId], references: [id], onDelete: Cascade)
  company      Company?       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent       User?          @relation("UserToDependents", fields: [parentId], references: [id])
  dependents   User[]         @relation("UserToDependents")
  transactions Transaction[]

  @@unique([cpf, unitId])
}

model Provider {
  id               String   @id @default(uuid())
  unitId           String
  name             String
  professionalName String?
  clinicName       String?
  registration     String?  // CRM, CREFITO, CRO, etc.
  cpfCnpj          String?
  category         String
  specialty        String?
  address          String?
  phone            String?
  whatsapp         String?
  email            String?
  photoUrl         String?
  rankingScore     Float    @default(0.0)
  bio              String?
  status           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  unit         Unit          @relation(fields: [unitId], references: [id], onDelete: Cascade)
  services     Service[]
  transactions Transaction[]
  rewards      Reward[]
}

model Service {
  id              String   @id @default(uuid())
  providerId      String
  description     String
  originalPrice   Decimal  @default(0.0)
  insurancePrice  Decimal  @default(0.0)
  discountedPrice Decimal  @default(0.0)
  discountType    String   @default("fixed") // "fixed" ou "percentage"
  discountValue   Decimal  @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  provider     Provider      @relation(fields: [providerId], references: [id], onDelete: Cascade)
  transactions Transaction[]
}

model Transaction {
  id              String   @id @default(uuid())
  userId          String
  providerId      String
  serviceId       String
  amountSaved     Decimal  @default(0.0)
  confirmedByUser Boolean  @default(false)
  rating          Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model Reward {
  id             String   @id @default(uuid())
  providerId     String
  name           String
  pointsRequired Int
  stock          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
}

model AuthUser {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         String   // 'super_admin' | 'admin_unit' | 'rh' | 'provider' | 'patient'
  unitId       String?
  companyId    String?
  providerId   String?
  userId       String?
  status       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions Session[]
}

model Session {
  id           String   @id @default(uuid())
  authUserId   String
  token        String   @unique
  refreshToken String?  @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  authUser AuthUser @relation(fields: [authUserId], references: [id], onDelete: Cascade)
}
