// packages/database/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Unit {
  id               String   @id @default(uuid())
  name             String
  subdomain        String   @unique
  settings         String?  // JSON string
  supportWhatsapp  String?
  featuresRewards  Boolean  @default(false)
  status           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  companies  Company[]
  users      User[]
  providers  Provider[]
  auditLogs  AuditLog[]
  categories Category[]
}

model Company {
  id                    String    @id @default(uuid())
  unitId                String
  externalCode          String?
  corporateName         String
  tradeName             String?
  cnpj                  String    @unique
  adminEmail            String?
  address               String?
  neighborhood          String?
  zipCode               String?
  city                  String?
  state                 String?
  phone                 String?
  memberSince           DateTime?
  dependentPaymentMode  String    @default("titular") // 'titular' | 'empresa'
  defaultCardType       String    @default("app")     // 'app' | 'physical'
  status                Boolean   @default(true)
  inactivationReason    String?
  inactivatedAt         DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  unit  Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)
  users User[]
}

model User {
  id                    String    @id @default(uuid())
  companyId             String?
  unitId                String
  externalCode          String?
  fullName              String
  cpf                   String
  type                  String    // 'titular' or 'dependente'
  parentId              String?
  gender                String?
  birthDate             DateTime?
  phone                 String?
  kinship               String?
  billingName           String?
  memberSince           DateTime?
  email                 String?
  whatsapp              String?
  firstAccessDone       Boolean   @default(false)
  inactivationReason    String?
  inactivatedAt         DateTime?
  inactivationLockUntil DateTime?
  cardTypeOverride      String?   // 'app' | 'physical' — null herda da empresa
  pointsBalance         Int       @default(0)
  photoUrl              String?
  settings              String?   // JSON: { notifications: { email, whatsapp, newProviders } }
  status                Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  unit          Unit                   @relation(fields: [unitId], references: [id], onDelete: Cascade)
  company       Company?               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent        User?                  @relation("UserToDependents", fields: [parentId], references: [id])
  dependents    User[]                 @relation("UserToDependents")
  transactions  Transaction[]
  contactClicks ProviderContactClick[]

  @@unique([cpf, unitId])
}

model Provider {
  id               String   @id @default(uuid())
  unitId           String
  name             String
  professionalName String?
  clinicName       String?
  registration     String?  // CRM, CREFITO, CRO, etc.
  cpfCnpj          String?
  category         String
  specialty        String?
  address          String?
  city             String?
  phone            String?
  whatsapp         String?
  email            String?
  photoUrl         String?
  rankingScore     Float    @default(0.0)
  bio              String?
  status           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  unit          Unit                   @relation(fields: [unitId], references: [id], onDelete: Cascade)
  services      Service[]
  transactions  Transaction[]
  rewards       Reward[]
  contactClicks ProviderContactClick[]
}

model Service {
  id                 String   @id @default(uuid())
  providerId         String
  description        String
  originalPrice      Decimal  @default(0.0)
  insurancePrice     Decimal  @default(0.0) // deprecated — mantido para histórico
  discountedPrice    Decimal  @default(0.0) // calculado: originalPrice * (1 - discountMaxPercent/100)
  discountType       String   @default("fixed") // "fixed" ou "percentage" (legado)
  discountValue      Decimal  @default(0)
  discountMinPercent Int?
  discountMaxPercent Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  provider     Provider      @relation(fields: [providerId], references: [id], onDelete: Cascade)
  transactions Transaction[]
}

model Transaction {
  id              String   @id @default(uuid())
  userId          String
  providerId      String
  serviceId       String
  amountSaved     Decimal  @default(0.0)
  confirmedByUser Boolean  @default(false)
  rating          Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model Reward {
  id             String   @id @default(uuid())
  providerId     String
  name           String
  pointsRequired Int
  stock          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
}

model AuthUser {
  id                     String   @id @default(uuid())
  email                  String   @unique
  passwordHash           String
  role                   String   // 'super_admin' | 'admin_unit' | 'rh' | 'provider' | 'patient'
  unitId                 String?
  companyId              String?
  providerId             String?
  userId                 String?
  displayName            String?
  lastLoginAt            DateTime?
  passwordChangeRequired Boolean  @default(false)
  status                 Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  sessions       Session[]
  passwordResets PasswordResetToken[]
}

model PasswordResetToken {
  id         String    @id @default(uuid())
  authUserId String
  tokenHash  String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  authUser AuthUser @relation(fields: [authUserId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([authUserId])
}

model AuditLog {
  id              String   @id @default(uuid())
  unitId          String?
  actorAuthUserId String?
  actorName       String?
  actorRole       String?
  entity          String
  entityId        String?
  action          String   // create | update | delete | login | reset_password | import | export | status_change | transfer
  diffBefore      Json?
  diffAfter       Json?
  ip              String?
  userAgent       String?
  createdAt       DateTime @default(now())

  unit Unit? @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([unitId, createdAt])
  @@index([entity, entityId])
  @@index([actorAuthUserId])
}

model ProviderContactClick {
  id         String   @id @default(uuid())
  providerId String
  userId     String?
  channel    String   // whatsapp | phone | maps | details
  ip         String?
  userAgent  String?
  clickedAt  DateTime @default(now())

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id])

  @@index([providerId, clickedAt])
}

model Session {
  id           String   @id @default(uuid())
  authUserId   String
  token        String   @unique
  refreshToken String?  @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  authUser AuthUser @relation(fields: [authUserId], references: [id], onDelete: Cascade)
}

model LoginAttempt {
  id         String   @id @default(uuid())
  authUserId String?
  email      String?
  ip         String?
  userAgent  String?
  success    Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([authUserId, createdAt])
  @@index([email, createdAt])
}

model Backup {
  id                  String   @id @default(uuid())
  unitId              String?
  fileName            String
  sizeBytes           Int      @default(0)
  storageUrl          String?
  createdByAuthUserId String?
  createdByName       String?
  status              String   @default("completed") // pending | completed | failed
  errorMessage        String?
  createdAt           DateTime @default(now())

  @@index([unitId, createdAt])
}

model Webhook {
  id        String   @id @default(uuid())
  unitId    String
  url       String
  events    String   // CSV: "user.created,transaction.created"
  secret    String
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deliveries WebhookDelivery[]

  @@index([unitId])
}

model WebhookDelivery {
  id           String   @id @default(uuid())
  webhookId    String
  event        String
  payload      Json
  responseCode Int?
  responseBody String?
  attempt      Int      @default(1)
  success      Boolean  @default(false)
  deliveredAt  DateTime @default(now())

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, deliveredAt])
}

model Category {
  id        String   @id @default(uuid())
  unitId    String
  name      String
  slug      String
  color     String?  // Ex.: 'bg-blue-50 text-blue-700'
  order     Int      @default(0)
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([unitId, slug])
  @@index([unitId, order])
}
